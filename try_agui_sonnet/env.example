# .env.example  ·  MAF Multi-Agent System
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI credentials
# ─────────────────────────────────────────────────────────────────────────────

# Your OpenAI (or Azure OpenAI / compatible) API key
OPENAI_API_KEY=sk-...

# Model name to use for all agents and the Magentic manager.
# Examples: gpt-4o  |  gpt-4o-mini  |  gpt-4-turbo  |  your-azure-deployment-name
OPENAI_MODEL=gpt-4o

# Custom base URL for a non-default endpoint (Azure OpenAI, local proxy, etc.).
# Leave commented out (or empty) to use the default https://api.openai.com/v1
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deploy

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Azure-specific settings
# Only needed if using Azure OpenAI with key-based auth AND a custom base URL.
# MAF's OpenAIChatCompletionClient also supports DefaultAzureCredential;
# see the MAF docs for credential-based auth.
# ─────────────────────────────────────────────────────────────────────────────
# AZURE_OPENAI_API_VERSION=2024-05-01-preview
