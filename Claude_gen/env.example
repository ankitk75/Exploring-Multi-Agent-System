# ─────────────────────────────────────────────────────────────────────────────
# Multi-Agent System — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM / OpenAI-compatible endpoint ─────────────────────────────────────────
# Standard OpenAI
OPENAI_API_KEY=sk-...

# Custom base URL — change to point at Azure OpenAI, LM Studio, Ollama, etc.
# Examples:
#   OpenAI (default) : https://api.openai.com/v1
#   Azure OpenAI     : https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   LM Studio        : http://localhost:1234/v1
#   Ollama           : http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use — must be available at the above endpoint
# Examples: gpt-4o | gpt-4o-mini | gpt-4-turbo | llama3 | mistral
MODEL_NAME=gpt-4o

# ── Agent A2A endpoints (logical only — resolved in-process) ─────────────────
# These are used for Agent Card URLs and A2A registry entries.
# In a distributed deployment, each agent would be a separate HTTP service
# at these addresses and you would start them with `agent-framework serve`.
MATH_AGENT_URL=http://localhost:8001
STRING_AGENT_URL=http://localhost:8002
MAGENTIC_MANAGER_URL=http://localhost:8000

# ── Optional: logging level ───────────────────────────────────────────────────
# LOG_LEVEL=DEBUG
